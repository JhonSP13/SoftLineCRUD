@{
    ViewData["Title"] = "Clientes";
}
<div class="center">
    <div class="text-center">
        <h1 class="display-4">Clientes</h1>
        <p>Lista de clientes:</p>
        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
            <a class="btn btn-outline-dark" role="button" asp-controller="Cliente" asp-action="AdicionarCliente">Adicionar Cliente</a>
            <br />
        </div>
    </div>
    <table class="table table-striped">
        <thead>
            <tr>
                <th scope="col">Código</th>
                <th scope="col">Nome</th>
                <th scope="col">Fantasia</th>
                <th scope="col">Documento</th>
                <th scope="col">Endereço</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <th scope="row">1</th>
                <td>Mark</td>
                <td>Otto</td>
                <td>mdo</td>
                <td></td>
                <td>
                    <div class="btn-group" role="group" aria-label="Basic outlined example">
                        <a role="button" class="btn btn-outline-warning" asp-controller="Cliente" asp-action="EditarCliente">Editar</a>
                        <a role="button" class="btn btn-outline-primary">Visualizar</a>
                        <a role="button" class="btn btn-outline-danger" asp-controller="Cliente" asp-action="ExcluirCliente">Excluir</a>
                    </div>
                </td>
            </tr>
            <tr>
                <th scope="row">2</th>
                <td>Jacob</td>
                <td>Thornton</td>
                <td>fat</td>
                <td></td>
                <td>
                    <div class="btn-group" role="group" aria-label="Basic outlined example">
                        <a role="button" class="btn btn-outline-warning" asp-controller="Cliente" asp-action="EditarCliente">Editar</a>
                        <a role="button" class="btn btn-outline-primary">Visualizar</a>
                        <a role="button" class="btn btn-outline-danger" asp-controller="Cliente" asp-action="ExcluirCliente">Excluir</a>
                    </div>
                </td>
            </tr>
            <tr>
                <th scope="row">3</th>
                <td>John</td>
                <td>Doe</td>
                <td>social</td>
                <td></td>
                <td>
                    <div class="btn-group" role="group" aria-label="Basic outlined example">
                        <a role="button" class="btn btn-outline-warning" asp-controller="Cliente" asp-action="EditarCliente">Editar</a>
                        <a role="button" class="btn btn-outline-primary">Visualizar</a>
                        <a role="button" class="btn btn-outline-danger" asp-controller="Cliente" asp-action="ExcluirCliente">Excluir</a>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>
